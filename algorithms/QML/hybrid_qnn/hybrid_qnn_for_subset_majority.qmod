qfunc my_ansatz(weights: real[], qbv: qbit[]) {
  repeat (index: qbv.len) {
    RY(weights[index], qbv[index]);
  }
  repeat (index: qbv.len - 1) {
    RZZ(weights[qbv.len + index], qbv[index:index + 2]);
  }
}

qfunc main(input_vec: real[4], weight: real[3], output result: qbit[]) {
  encode_on_bloch(input_vec, result);
  my_ansatz(weight, result);
}
