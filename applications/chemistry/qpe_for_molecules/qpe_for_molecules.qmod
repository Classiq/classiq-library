qfunc qft_no_swap_expanded___0(qbv: qbit[7]) {
  repeat (i: 7) {
    H(qbv[i]);
    repeat (j: (7 - i) - 1) {
      CPHASE(pi / (2 ** (j + 1)), qbv[(i + j) + 1], qbv[i]);
    }
  }
}

qfunc qft_expanded___0(target: qbit[7]) {
  repeat (index: 3.5) {
    SWAP(target[index], target[6 - index]);
  }
  qft_no_swap_expanded___0(target);
}

qfunc qpe_flexible_expanded___0(phase: qbit[7], state_captured__main__0: qbit[6]) {
  apply_to_all_expanded___0(phase);
  repeat (index: 7) {
    control (phase[index]) {
      unitary_with_power_0_lambda___0_0_expanded___0(2 ** index, state_captured__main__0);
    }
  }
  invert {
    qft_expanded___0(phase);
  }
}

qfunc main(output state: qbit[6], output phase: qnum<7, True, 7>) {
  prepare_basis_state_expanded___0(state);
  allocate(7, phase);
  qpe_flexible_expanded___0(phase, state);
}
