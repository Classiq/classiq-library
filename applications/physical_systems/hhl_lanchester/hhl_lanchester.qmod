qfunc qft_no_swap_expanded___0(qbv: qbit[6]) {
  repeat (i: 6) {
    H(qbv[i]);
    repeat (j: (6 - i) - 1) {
      CPHASE(pi / (2 ** (j + 1)), qbv[(i + j) + 1], qbv[i]);
    }
  }
}

qfunc qft_expanded___0(target: qbit[6]) {
  repeat (index: 3.0) {
    SWAP(target[index], target[5 - index]);
  }
  qft_no_swap_expanded___0(target);
}

qfunc qpe_flexible_expanded___0(phase: qbit[6], time_index_and_group_captured__main__0: TimeIndexAndGroup) {
  apply_to_all_expanded___0(phase);
  repeat (index: 6) {
    control (phase[index]) {
      unitary_with_power_0_lambda___0_0_expanded___0(2 ** index, time_index_and_group_captured__main__0);
    }
  }
  invert {
    qft_expanded___0(phase);
  }
}

qfunc qpe_expanded___0(phase: qnum<6, False, 6>, time_index_and_group_captured__main__0: TimeIndexAndGroup) {
  qpe_flexible_expanded___0(phase, time_index_and_group_captured__main__0);
}

