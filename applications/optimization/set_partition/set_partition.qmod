qstruct QAOAVars {
  x: qbit[10];
}

qfunc main(params: real[6], output v: QAOAVars) {
  allocate(v.size, v);
  hadamard_transform(v);
  repeat (i: 3) {
    phase (-((((((((((((8 * v.x[0]) + (18 * v.x[1])) + (6 * v.x[2])) + (18 * v.x[3])) + (4 * v.x[4])) + (12 * v.x[5])) + (18 * v.x[6])) + (20 * v.x[7])) + (14 * v.x[8])) + (16 * v.x[9])) - 67) ** 2), params[i]);
    apply_to_all(lambda(q) {
      RX(params[3 + i], q);
    }, v);
  }
}
