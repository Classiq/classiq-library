qfunc qft_no_swap_expanded___0(qbv: qbit[4]) {
  repeat (i: 4) {
    H(qbv[i]);
    repeat (j: (4 - i) - 1) {
      CPHASE(pi / (2 ** (j + 1)), qbv[(i + j) + 1], qbv[i]);
    }
  }
}

qfunc qft_expanded___0(target: qbit[4]) {
  repeat (index: 2.0) {
    SWAP(target[index], target[3 - index]);
  }
  qft_no_swap_expanded___0(target);
}

qfunc qpe_flexible_expanded___0(phase: qbit[4], res_captured__my_hhl__1: qbit[2]) {
  apply_to_all_expanded___0(phase);
  repeat (index: 4) {
    control (phase[index]) {
      unitary_with_power_0_lambda___0_0_expanded___0(2 ** index, res_captured__my_hhl__1);
    }
  }
  invert {
    qft_expanded___0(phase);
  }
}

qfunc qpe_expanded___0(phase: qnum<4, False, 4>, res_captured__my_hhl__1: qbit[2]) {
  qpe_flexible_expanded___0(phase, res_captured__my_hhl__1);
}

