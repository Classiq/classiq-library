qfunc simple_eig_inv_expanded___0(const phase: qnum<4, False, 4>, output indicator: qbit) {
  allocate(1, indicator);
  assign_amplitude_table_expanded___0(phase, indicator);
}

qfunc my_hhl_expanded___0(b: real[], output res: qbit[2], output phase: qnum<4, False, 4>, output indicator: qbit) {
  load_b_expanded___0(b, res);
  allocate(4, False, 4, phase);
  within {
    qpe_expanded___0(phase, res);
  } apply {
    simple_eig_inv_expanded___0(phase, indicator);
  }
}

