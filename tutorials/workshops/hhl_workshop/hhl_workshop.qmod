qfunc load_b_expanded___0(b: real[], output res: qbit[2]) {
  prepare_amplitudes(b, 0.0, res);
}

qfunc apply_to_all_expanded___0(target: qbit[4]) {
  repeat (index: 4) {
    H(target[index]);
  }
}

